# Configuración para ambiente PRODUCCIÓN
# COPIA ESTE ARCHIVO A config.prod.env Y ACTUALIZA LOS VALORES
# IMPORTANTE: La contraseña debe gestionarse a través de:
#   1. ~/.pgpass (para PostgreSQL en modo direct)
#   2. Variables de entorno cifradas en CI/CD
#   3. Sistema de secretos (AWS Secrets Manager, Vault, etc.)

RUAF_MODE=direct
PGHOST=10.10.11.161
PGPORT=5432
PGUSER=jamaica
PGDATABASE=interssi
# PGPASSWORD NO SE ESPECIFICA AQUÍ - usar .pgpass o variable de entorno

# Configuración FTP
RUAF_SITE_FTP="Ministerio 2"
RUAF_FILEZILLA="FileZilla.xml"
RUAF_DEST_DIR="."
RUAF_LOGDIR="logs"

# Seguridad SSL
# NOTA: El servidor del ministerio tiene un certificado inválido pero funciona correctamente.
# Se desactiva la verificación por defecto en producción para evitar problemas de conectividad.
# El riesgo MITM es bajo en la red interna. Cambiar solo si el certificado es resuelto.
RUAF_SKIP_SSL_VERIFY=1
