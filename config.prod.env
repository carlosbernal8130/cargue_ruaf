# Configuración para ambiente PRODUCCIÓN
# NOTA: Este archivo contiene configuración NO SENSIBLE
# Las credenciales se cargan desde .pgpass o variables de entorno
# Ver DEVELOPMENT.md para instrucciones

RUAF_MODE=direct
PGHOST=10.10.11.161
PGPORT=5432
PGUSER=jamaica
PGDATABASE=interssi
# PGPASSWORD se obtiene desde .pgpass - NO especificar aquí

# Configuración FTP
RUAF_SITE_FTP="Ministerio 2"
RUAF_FILEZILLA="FileZilla.xml"
RUAF_DEST_DIR="."
RUAF_LOGDIR="logs"

# Seguridad SSL
# NOTA: El servidor del ministerio (ftp.minsalud.gov.co) tiene un certificado inválido
# pero funciona correctamente. Se desactiva la verificación por defecto en producción
# para evitar problemas de conectividad. El riesgo MITM es bajo en la red interna.
RUAF_SKIP_SSL_VERIFY=1
