# Configuración para ambiente DOCKER (desarrollo/testing)
# COPIA ESTE ARCHIVO A config.docker.env Y ACTUALIZA LOS VALORES

RUAF_MODE=docker
RUAF_CONTAINER=mi_postgres_data
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGDATABASE=bdua_fosyga
# PGPASSWORD se carga desde .pgpass (ver DEVELOPMENT.md)

# Configuración FTP
RUAF_SITE_FTP="Ministerio 2"
RUAF_FILEZILLA="FileZilla.xml"
RUAF_DEST_DIR="."
RUAF_LOGDIR="logs"

# Seguridad SSL (SOLO para desarrollo/testing)
# Descomenta para deshabilitar validación de certificados SSL (inseguro)
# RUAF_SKIP_SSL_VERIFY=1
