# Configuración para ambiente DOCKER (desarrollo/testing)
# NOTA: Este archivo contiene configuración NO SENSIBLE
# Las credenciales se cargan desde .pgpass o variables de entorno
# Ver DEVELOPMENT.md para instrucciones

RUAF_MODE=docker
RUAF_CONTAINER=mi_postgres_data
PGUSER=postgres
PGDATABASE=bdua_fosyga
# PGPASSWORD se obtiene desde .pgpass - NO especificar aquí

# Configuración FTP
RUAF_SITE_FTP="Ministerio 2"
RUAF_FILEZILLA="FileZilla.xml"
RUAF_DEST_DIR="."
RUAF_LOGDIR="logs"

# Seguridad SSL (SOLO para desarrollo/testing)
# Descomenta la siguiente línea para deshabilitar validación de certificados SSL
# RUAF_SKIP_SSL_VERIFY=1
